APP_NAME="NLP Semantic Lab"
APP_VERSION="0.1.0"
DATABASE_URL=postgresql://user:password@localhost:5432/nlp_similarity_db
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL_NAME=bge-m3

# Redis Cache Configuration (Optional - app works without Redis)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# RabbitMQ Configuration (Optional - for async embeddings processing)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE_NAME=embeddings_queue
QUEUE_ENABLED=false

# OpenAI Configuration (for RAG module)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_API_BASE=https://api.openai.com/v1

# LLM Provider Configuration
LLM_PROVIDER=chatgpt  # Options: chatgpt, claude, deepseek, ollama

# Claude Configuration (if using Claude)
CLAUDE_API_KEY=your-claude-api-key-here
CLAUDE_MODEL=claude-3-sonnet-20240229

# DeepSeek Configuration (if using DeepSeek)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# Ollama Configuration (if using Ollama for LLM chat)
OLLAMA_LLM_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2

SEQ_ENABLED=true
SEQ_SERVER_URL=http://localhost:5341
SEQ_API_KEY=your-api-key-here  # Optional

# API Key Authentication (disabled by default)
API_KEY_ENABLED=false
API_KEY=your-secret-api-key-here

# CORS Allowed Origins (use ["*"] for development)
CORS_ALLOWED_ORIGINS=["*"]

HF_TOKEN=your-huggingface-token-here
